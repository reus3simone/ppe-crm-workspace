# ====================================================
# Supabase 数据库配置模板
# 使用方法：
#   1. 复制本文件到 .streamlit/secrets.toml
#   2. 填入你的 Supabase 数据库连接信息
#   3. 部署到 Streamlit Cloud 时，在 Dashboard 的
#      Settings → Secrets 中粘贴以下内容（去掉注释）
# ====================================================

supabase_host = "db.xxxxxxxxxxxxxx.supabase.co"
supabase_port = "5432"
supabase_database = "postgres"
supabase_user = "postgres"
supabase_password = "你的数据库密码"

# 这些信息可以在 Supabase 控制台 → Project Settings → Database
# 找到 "Connection string" / "URI" 字段获取
